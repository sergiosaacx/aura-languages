      "transcript_json": "{\"videoId\": \"IfSUyYlntlc\", \"gaps\": [{\"start\": 0, \"end\": 3.6, \"nextT\": 4.1}], \"lyrics\": [{\"t\": 4.1, \"end\": 8.26, \"text\": \"Hey guys, wait a second.\", \"words\": [{\"w\": \"Hey\", \"t\": 4.1}, {\"w\": \"guys\", \"t\": 4.98}, {\"w\": \"wait\", \"t\": 5.36}, {\"w\": \"a\", \"t\": 7.38}, {\"w\": \"second\", \"t\": 8.26}]}, {\"t\": 14.8, \"end\": 17.88, \"text\": \"Our next guest has been here a very long time.\", \"words\": [{\"w\": \"next\", \"t\": 14.84}, {\"w\": \"guest\", \"t\": 15.26}, {\"w\": \"has\", \"t\": 15.68}, {\"w\": \"been\", \"t\": 16.14}, {\"w\": \"here\", \"t\": 16.14}, {\"w\": \"a\", \"t\": 16.36}, {\"w\": \"very\", \"t\": 16.66}, {\"w\": \"long\", \"t\": 17.06}, {\"w\": \"time\", \"t\": 17.4}]}, {\"t\": 18.32, \"end\": 19.7, \"text\": \"She's a whale shark.\", \"words\": [{\"w\": \"She's\", \"t\": 18.32}, {\"w\": \"a\", \"t\": 18.88}, {\"w\": \"whale\", \"t\": 19.08}, {\"w\": \"shark\", \"t\": 19.38}]}, {\"t\": 20.2, \"end\": 21.58, \"text\": \"Her name is Destiny.\", \"words\": [{\"w\": \"Her\", \"t\": 20.2}, {\"w\": \"name\", \"t\": 20.2}, {\"w\": \"is\", \"t\": 20.52}, {\"w\": \"Destiny\", \"t\": 21.12}]}, {\"t\": 22.5, \"end\": 22.5, \"text\": \"\", \"words\": [{\"w\": \"Really\", \"t\": 22.54}]}, {\"t\": 22.54, \"end\": 23.08, \"text\": \"Really?\", \"words\": [{\"w\": \"Really\", \"t\": 22.54}, {\"w\": \"You'll\", \"t\": 23.16}]}, {\"t\": 23.16, \"end\": 27.9, \"text\": \"You'll notice she's extremely nearsighted and has trouble navigating her environment.\", \"words\": [{\"w\": \"You'll\", \"t\": 23.16}, {\"w\": \"notice\", \"t\": 23.7}, {\"w\": \"she's\", \"t\": 23.7}, {\"w\": \"extremely\", \"t\": 24.32}, {\"w\": \"nearsighted\", \"t\": 24.76}, {\"w\": \"and\", \"t\": 25.78}, {\"w\": \"has\", \"t\": 26.12}, {\"w\": \"trouble\", \"t\": 26.34}, {\"w\": \"navigating\", \"t\": 26.64}, {\"w\": \"her\", \"t\": 27.14}, {\"w\": \"environment\", \"t\": 27.52}]}, {\"t\": 28.78, \"end\": 31.06, \"text\": \"Oh, and here she comes now!\", \"words\": [{\"w\": \"Oh\", \"t\": 28.78}, {\"w\": \"and\", \"t\": 29.18}, {\"w\": \"here\", \"t\": 29.58}, {\"w\": \"she\", \"t\": 29.8}, {\"w\": \"comes\", \"t\": 29.96}, {\"w\": \"now\", \"t\": 30.24}, {\"w\": \"Ooh\", \"t\": 31.2}]}, {\"t\": 31.2, \"end\": 31.44, \"text\": \"Ooh!\", \"words\": [{\"w\": \"Ooh\", \"t\": 31.2}]}, {\"t\": 32.28, \"end\": 32.66, \"text\": \"Destiny?\", \"words\": [{\"w\": \"Destiny\", \"t\": 32.28}]}, {\"t\": 33.36, \"end\": 34.3, \"text\": \"You're a fish?\", \"words\": [{\"w\": \"You're\", \"t\": 33.36}, {\"w\": \"a\", \"t\": 33.76}, {\"w\": \"fish\", \"t\": 34.16}]}, {\"t\": 36.94, \"end\": 37.74, \"text\": \"Wait, what?\", \"words\": [{\"w\": \"Wait\", \"t\": 36.94}, {\"w\": \"what\", \"t\": 37.34}, {\"w\": \"Hi\", \"t\": 37.74}]}, {\"t\": 37.74, \"end\": 38.1, \"text\": \"Hi!\", \"words\": [{\"w\": \"Hi\", \"t\": 37.74}]}, {\"t\": 38.4, \"end\": 38.96, \"text\": \"Hello there!\", \"words\": [{\"w\": \"Hello\", \"t\": 38.4}, {\"w\": \"there\", \"t\": 38.6}, {\"w\": \"Can\", \"t\": 39.24}]}, {\"t\": 39.24, \"end\": 40.0, \"text\": \"Can you help me?\", \"words\": [{\"w\": \"Can\", \"t\": 39.24}, {\"w\": \"you\", \"t\": 39.42}, {\"w\": \"help\", \"t\": 39.6}, {\"w\": \"me\", \"t\": 39.82}]}, {\"t\": 42.32, \"end\": 44.02, \"text\": \"Alright, I'll go with you.\", \"words\": [{\"w\": \"Alright\", \"t\": 42.32}, {\"w\": \"I'll\", \"t\": 42.86}, {\"w\": \"go\", \"t\": 43.16}, {\"w\": \"with\", \"t\": 43.28}, {\"w\": \"you\", \"t\": 43.46}]}, {\"t\": 44.72, \"end\": 45.26, \"text\": \"Excuse me.\", \"words\": [{\"w\": \"Excuse\", \"t\": 44.72}, {\"w\": \"me\", \"t\": 45.08}, {\"w\": \"Hi\", \"t\": 45.52}]}, {\"t\": 45.52, \"end\": 45.92, \"text\": \"Hi.\", \"words\": [{\"w\": \"Hi\", \"t\": 45.52}, {\"w\": \"Who\", \"t\": 46.04}]}, {\"t\": 46.04, \"end\": 46.68, \"text\": \"Who is that?\", \"words\": [{\"w\": \"Who\", \"t\": 46.04}, {\"w\": \"is\", \"t\": 46.22}, {\"w\": \"that\", \"t\": 46.42}, {\"w\": \"Is\", \"t\": 46.92}]}, {\"t\": 46.92, \"end\": 48.14, \"text\": \"Is that blue blob talking?\", \"words\": [{\"w\": \"Is\", \"t\": 46.92}, {\"w\": \"that\", \"t\": 47.22}, {\"w\": \"blue\", \"t\": 47.4}, {\"w\": \"blob\", \"t\": 47.6}, {\"w\": \"talking\", \"t\": 47.76}, {\"w\": \"Can\", \"t\": 48.22}, {\"w\": \"you\", \"t\": 48.4}]}, {\"t\": 48.22, \"end\": 48.88, \"text\": \"Can you help me?\", \"words\": [{\"w\": \"Can\", \"t\": 48.22}, {\"w\": \"you\", \"t\": 48.4}, {\"w\": \"help\", \"t\": 48.64}, {\"w\": \"me\", \"t\": 48.72}, {\"w\": \"I\", \"t\": 48.88}, {\"w\": \"lost\", \"t\": 49.1}]}, {\"t\": 48.88, \"end\": 49.88, \"text\": \"I lost my family.\", \"words\": [{\"w\": \"help\", \"t\": 48.64}, {\"w\": \"me\", \"t\": 48.72}, {\"w\": \"I\", \"t\": 48.88}, {\"w\": \"lost\", \"t\": 49.1}, {\"w\": \"my\", \"t\": 49.24}, {\"w\": \"family\", \"t\": 49.88}, {\"w\": \"You\", \"t\": 50.0}]}, {\"t\": 50.0, \"end\": 50.72, \"text\": \"You lost your family?\", \"words\": [{\"w\": \"family\", \"t\": 49.88}, {\"w\": \"You\", \"t\": 50.0}, {\"w\": \"lost\", \"t\": 50.24}, {\"w\": \"your\", \"t\": 50.24}, {\"w\": \"family\", \"t\": 50.58}, {\"w\": \"Well\", \"t\": 50.9}]}, {\"t\": 50.9, \"end\": 53.84, \"text\": \"Well, it's a long story and truth be told, I don't remember most of it.\", \"words\": [{\"w\": \"Well\", \"t\": 50.9}, {\"w\": \"it's\", \"t\": 51.28}, {\"w\": \"a\", \"t\": 51.44}, {\"w\": \"long\", \"t\": 51.62}, {\"w\": \"story\", \"t\": 51.76}, {\"w\": \"and\", \"t\": 52.04}, {\"w\": \"truth\", \"t\": 52.24}, {\"w\": \"be\", \"t\": 52.42}, {\"w\": \"told\", \"t\": 52.72}, {\"w\": \"I\", \"t\": 52.82}, {\"w\": \"don't\", \"t\": 52.98}, {\"w\": \"remember\", \"t\": 53.08}, {\"w\": \"most\", \"t\": 53.36}, {\"w\": \"of\", \"t\": 53.62}, {\"w\": \"it\", \"t\": 53.8}, {\"w\": \"Oh\", \"t\": 53.86}, {\"w\": \"that\", \"t\": 54.14}]}, {\"t\": 53.86, \"end\": 55.14, \"text\": \"Oh, that is so sad!\", \"words\": [{\"w\": \"of\", \"t\": 53.62}, {\"w\": \"it\", \"t\": 53.8}, {\"w\": \"Oh\", \"t\": 53.86}, {\"w\": \"that\", \"t\": 54.14}, {\"w\": \"is\", \"t\": 54.3}, {\"w\": \"so\", \"t\": 54.46}, {\"w\": \"sad\", \"t\": 54.8}, {\"w\": \"You\", \"t\": 55.2}, {\"w\": \"poor\", \"t\": 55.32}]}, {\"t\": 55.2, \"end\": 55.52, \"text\": \"You poor thing!\", \"words\": [{\"w\": \"You\", \"t\": 55.2}, {\"w\": \"poor\", \"t\": 55.32}, {\"w\": \"thing\", \"t\": 55.5}]}, {\"t\": 59.24, \"end\": 59.72, \"text\": \"Sorry.\", \"words\": [{\"w\": \"Sorry\", \"t\": 59.24}]}, {\"t\": 60.54, \"end\": 61.16, \"text\": \"Not a great swimmer.\", \"words\": [{\"w\": \"Not\", \"t\": 60.54}, {\"w\": \"a\", \"t\": 60.54}, {\"w\": \"great\", \"t\": 60.58}, {\"w\": \"swimmer\", \"t\": 60.78}]}, {\"t\": 61.94, \"end\": 62.54, \"text\": \"Can't see very well.\", \"words\": [{\"w\": \"Can't\", \"t\": 61.94}, {\"w\": \"see\", \"t\": 61.96}, {\"w\": \"very\", \"t\": 62.1}, {\"w\": \"well\", \"t\": 62.4}, {\"w\": \"Oh\", \"t\": 62.66}]}, {\"t\": 62.66, \"end\": 63.94, \"text\": \"Oh, I think you swim beautifully.\", \"words\": [{\"w\": \"well\", \"t\": 62.4}, {\"w\": \"Oh\", \"t\": 62.66}, {\"w\": \"I\", \"t\": 62.86}, {\"w\": \"think\", \"t\": 63.0}, {\"w\": \"you\", \"t\": 63.16}, {\"w\": \"swim\", \"t\": 63.44}, {\"w\": \"beautifully\", \"t\": 63.46}, {\"w\": \"In\", \"t\": 64.08}]}, {\"t\": 64.08, \"end\": 66.12, \"text\": \"In fact, I've never seen a fish swim like that before.\", \"words\": [{\"w\": \"In\", \"t\": 64.08}, {\"w\": \"fact\", \"t\": 64.38}, {\"w\": \"I've\", \"t\": 64.38}, {\"w\": \"never\", \"t\": 64.6}, {\"w\": \"seen\", \"t\": 64.76}, {\"w\": \"a\", \"t\": 64.9}, {\"w\": \"fish\", \"t\": 65.16}, {\"w\": \"swim\", \"t\": 65.16}, {\"w\": \"like\", \"t\": 65.38}, {\"w\": \"that\", \"t\": 65.56}, {\"w\": \"before\", \"t\": 65.82}]}, {\"t\": 67.0, \"end\": 67.96, \"text\": \"Thank you!\", \"words\": [{\"w\": \"Thank\", \"t\": 67.0}, {\"w\": \"you\", \"t\": 67.48}]}, {\"t\": 68.72, \"end\": 69.68, \"text\": \"You're welcome!\", \"words\": [{\"w\": \"You're\", \"t\": 68.72}, {\"w\": \"welcome\", \"t\": 69.2}]}, {\"t\": 70.72, \"end\": 71.94, \"text\": \"Wait, say that again.\", \"words\": [{\"w\": \"Wait\", \"t\": 70.72}, {\"w\": \"say\", \"t\": 71.08}, {\"w\": \"that\", \"t\": 71.56}, {\"w\": \"again\", \"t\": 71.7}]}, {\"t\": 73.12, \"end\": 74.08, \"text\": \"You're welcome!\", \"words\": [{\"w\": \"You're\", \"t\": 73.12}, {\"w\": \"welcome\", \"t\": 73.6}]}, {\"t\": 75.44, \"end\": 75.82, \"text\": \"Dory?\", \"words\": [{\"w\": \"Dory\", \"t\": 75.44}, {\"w\": \"Yes\", \"t\": 76.08}]}, {\"t\": 76.08, \"end\": 76.56, \"text\": \"Yes.\", \"words\": [{\"w\": \"Yes\", \"t\": 76.08}, {\"w\": \"Dory\", \"t\": 76.7}]}, {\"t\": 76.7, \"end\": 77.04, \"text\": \"Dory.\", \"words\": [{\"w\": \"Dory\", \"t\": 76.7}, {\"w\": \"Yes\", \"t\": 77.26}]}, {\"t\": 77.26, \"end\": 77.68, \"text\": \"Yes.\", \"words\": [{\"w\": \"Yes\", \"t\": 77.26}, {\"w\": \"Dory\", \"t\": 77.84}]}, {\"t\": 77.84, \"end\": 78.08, \"text\": \"Dory?\", \"words\": [{\"w\": \"Dory\", \"t\": 77.84}, {\"w\": \"Yes\", \"t\": 78.22}]}, {\"t\": 78.22, \"end\": 78.7, \"text\": \"Yes.\", \"words\": [{\"w\": \"Yes\", \"t\": 78.22}]}, {\"t\": 79.34, \"end\": 79.82, \"text\": \"Dory!\", \"words\": [{\"w\": \"Dory\", \"t\": 79.34}, {\"w\": \"Yes\", \"t\": 80.02}]}, {\"t\": 80.02, \"end\": 80.36, \"text\": \"Yes.\", \"words\": [{\"w\": \"Yes\", \"t\": 80.02}]}, {\"t\": 80.68, \"end\": 81.8, \"text\": \"You and I were friends!\", \"words\": [{\"w\": \"You\", \"t\": 80.68}, {\"w\": \"and\", \"t\": 80.84}, {\"w\": \"I\", \"t\": 81.0}, {\"w\": \"were\", \"t\": 81.06}, {\"w\": \"friends\", \"t\": 81.28}, {\"w\": \"No\", \"t\": 82.04}]}, {\"t\": 82.04, \"end\": 82.52, \"text\": \"No.\", \"words\": [{\"w\": \"No\", \"t\": 82.04}, {\"w\": \"Dory\", \"t\": 82.72}]}, {\"t\": 82.72, \"end\": 84.14, \"text\": \"Dory, it's me, Destiny!\", \"words\": [{\"w\": \"Dory\", \"t\": 82.72}, {\"w\": \"it's\", \"t\": 83.06}, {\"w\": \"me\", \"t\": 83.26}, {\"w\": \"Destiny\", \"t\": 83.72}]}, {\"t\": 84.48, \"end\": 85.12, \"text\": \"You know me?\", \"words\": [{\"w\": \"You\", \"t\": 84.48}, {\"w\": \"know\", \"t\": 84.72}, {\"w\": \"me\", \"t\": 84.86}, {\"w\": \"Of\", \"t\": 85.12}]}, {\"t\": 85.12, \"end\": 85.86, \"text\": \"Of course!\", \"words\": [{\"w\": \"me\", \"t\": 84.86}, {\"w\": \"Of\", \"t\": 85.12}, {\"w\": \"course\", \"t\": 85.54}]}, {\"t\": 86.22, \"end\": 87.82, \"text\": \"We'd talk through the pipes when we were little!\", \"words\": [{\"w\": \"We'd\", \"t\": 86.22}, {\"w\": \"talk\", \"t\": 86.48}, {\"w\": \"through\", \"t\": 86.6}, {\"w\": \"the\", \"t\": 86.74}, {\"w\": \"pipes\", \"t\": 87.1}, {\"w\": \"when\", \"t\": 87.1}, {\"w\": \"we\", \"t\": 87.28}, {\"w\": \"were\", \"t\": 87.38}, {\"w\": \"little\", \"t\": 87.6}, {\"w\": \"We\", \"t\": 88.08}]}, {\"t\": 88.08, \"end\": 89.08, \"text\": \"We were pipe pals!\", \"words\": [{\"w\": \"We\", \"t\": 88.08}, {\"w\": \"were\", \"t\": 88.16}, {\"w\": \"pipe\", \"t\": 88.34}, {\"w\": \"pals\", \"t\": 88.6}, {\"w\": \"We\", \"t\": 89.14}, {\"w\": \"were\", \"t\": 89.3}]}, {\"t\": 89.14, \"end\": 89.6, \"text\": \"We were?\", \"words\": [{\"w\": \"We\", \"t\": 89.14}, {\"w\": \"were\", \"t\": 89.3}]}, {\"t\": 90.36, \"end\": 91.78, \"text\": \"Aw, you're so pretty!\", \"words\": [{\"w\": \"Aw\", \"t\": 90.36}, {\"w\": \"you're\", \"t\": 90.76}, {\"w\": \"so\", \"t\": 90.98}, {\"w\": \"pretty\", \"t\": 91.28}, {\"w\": \"So\", \"t\": 92.04}]}, {\"t\": 92.04, \"end\": 93.08, \"text\": \"So you know where I'm from?\", \"words\": [{\"w\": \"So\", \"t\": 92.04}, {\"w\": \"you\", \"t\": 92.2}, {\"w\": \"know\", \"t\": 92.34}, {\"w\": \"where\", \"t\": 92.5}, {\"w\": \"I'm\", \"t\": 92.66}, {\"w\": \"from\", \"t\": 92.84}, {\"w\": \"Yep\", \"t\": 93.24}]}, {\"t\": 93.24, \"end\": 95.1, \"text\": \"Yep, you are from the open ocean exhibit.\", \"words\": [{\"w\": \"Yep\", \"t\": 93.24}, {\"w\": \"you\", \"t\": 93.56}, {\"w\": \"are\", \"t\": 93.86}, {\"w\": \"from\", \"t\": 94.06}, {\"w\": \"the\", \"t\": 94.18}, {\"w\": \"open\", \"t\": 94.36}, {\"w\": \"ocean\", \"t\": 94.56}, {\"w\": \"exhibit\", \"t\": 94.78}]}, {\"t\": 95.68, \"end\": 96.92, \"text\": \"I'm from the open ocean exhibit?\", \"words\": [{\"w\": \"I'm\", \"t\": 95.68}, {\"w\": \"from\", \"t\": 96.04}, {\"w\": \"the\", \"t\": 96.1}, {\"w\": \"open\", \"t\": 96.32}, {\"w\": \"ocean\", \"t\": 96.46}, {\"w\": \"exhibit\", \"t\": 96.7}]}, {\"t\": 97.24, \"end\": 98.62, \"text\": \"Then that's where my parents are!\", \"words\": [{\"w\": \"Then\", \"t\": 97.24}, {\"w\": \"that's\", \"t\": 97.64}, {\"w\": \"where\", \"t\": 97.88}, {\"w\": \"my\", \"t\": 98.0}, {\"w\": \"parents\", \"t\": 98.24}, {\"w\": \"are\", \"t\": 98.38}, {\"w\": \"We\", \"t\": 98.68}]}, {\"t\": 98.68, \"end\": 99.38, \"text\": \"We gotta go.\", \"words\": [{\"w\": \"We\", \"t\": 98.68}, {\"w\": \"gotta\", \"t\": 99.06}, {\"w\": \"go\", \"t\": 99.16}, {\"w\": \"Can\", \"t\": 99.52}]}, {\"t\": 99.52, \"end\": 100.24, \"text\": \"Can you take me there?\", \"words\": [{\"w\": \"Can\", \"t\": 99.52}, {\"w\": \"you\", \"t\": 99.68}, {\"w\": \"take\", \"t\": 99.78}, {\"w\": \"me\", \"t\": 99.92}, {\"w\": \"there\", \"t\": 100.14}]}, {\"t\": 100.64, \"end\": 103.1, \"text\": \"Ah, kinda tough for a whale to travel around here.\", \"words\": [{\"w\": \"Ah\", \"t\": 100.64}, {\"w\": \"kinda\", \"t\": 101.04}, {\"w\": \"tough\", \"t\": 101.34}, {\"w\": \"for\", \"t\": 101.6}, {\"w\": \"a\", \"t\": 101.82}, {\"w\": \"whale\", \"t\": 102.18}, {\"w\": \"to\", \"t\": 102.18}, {\"w\": \"travel\", \"t\": 102.44}, {\"w\": \"around\", \"t\": 102.68}, {\"w\": \"here\", \"t\": 102.98}, {\"w\": \"Can\", \"t\": 103.18}, {\"w\": \"you\", \"t\": 103.26}]}, {\"t\": 103.18, \"end\": 105.26, \"text\": \"Can you please keep it down over there?\", \"words\": [{\"w\": \"here\", \"t\": 102.98}, {\"w\": \"Can\", \"t\": 103.18}, {\"w\": \"you\", \"t\": 103.26}, {\"w\": \"please\", \"t\": 103.5}, {\"w\": \"keep\", \"t\": 103.86}, {\"w\": \"it\", \"t\": 104.06}, {\"w\": \"down\", \"t\": 104.52}, {\"w\": \"over\", \"t\": 104.54}, {\"w\": \"there\", \"t\": 104.9}, {\"w\": \"My\", \"t\": 105.38}]}, {\"t\": 105.38, \"end\": 106.14, \"text\": \"My head hurts.\", \"words\": [{\"w\": \"My\", \"t\": 105.38}, {\"w\": \"head\", \"t\": 105.64}, {\"w\": \"hurts\", \"t\": 105.84}, {\"w\": \"Who's\", \"t\": 106.38}]}, {\"t\": 106.38, \"end\": 107.06, \"text\": \"Who's that?\", \"words\": [{\"w\": \"Who's\", \"t\": 106.38}, {\"w\": \"that\", \"t\": 106.78}]}, {\"t\": 107.38, \"end\": 108.44, \"text\": \"That's my neighbor, Bailey.\", \"words\": [{\"w\": \"That's\", \"t\": 107.38}, {\"w\": \"my\", \"t\": 107.78}, {\"w\": \"neighbor\", \"t\": 108.18}, {\"w\": \"Bailey\", \"t\": 108.34}, {\"w\": \"He\", \"t\": 108.48}]}, {\"t\": 108.48, \"end\": 110.0, \"text\": \"He was brought in with a head injury.\", \"words\": [{\"w\": \"Bailey\", \"t\": 108.34}, {\"w\": \"He\", \"t\": 108.48}, {\"w\": \"was\", \"t\": 108.84}, {\"w\": \"brought\", \"t\": 109.04}, {\"w\": \"in\", \"t\": 109.2}, {\"w\": \"with\", \"t\": 109.32}, {\"w\": \"a\", \"t\": 109.48}, {\"w\": \"head\", \"t\": 109.58}, {\"w\": \"injury\", \"t\": 109.76}, {\"w\": \"I\", \"t\": 110.14}, {\"w\": \"know\", \"t\": 110.24}]}, {\"t\": 110.14, \"end\": 111.24, \"text\": \"I know you're talking about me, Destiny.\", \"words\": [{\"w\": \"I\", \"t\": 110.14}, {\"w\": \"know\", \"t\": 110.24}, {\"w\": \"you're\", \"t\": 110.32}, {\"w\": \"talking\", \"t\": 110.68}, {\"w\": \"about\", \"t\": 110.68}, {\"w\": \"me\", \"t\": 110.86}, {\"w\": \"Destiny\", \"t\": 111.16}, {\"w\": \"He\", \"t\": 111.38}, {\"w\": \"thinks\", \"t\": 111.52}]}, {\"t\": 111.38, \"end\": 114.32, \"text\": \"He thinks he can't use his echolocation, but I've overheard the doctors talking.\", \"words\": [{\"w\": \"Destiny\", \"t\": 111.16}, {\"w\": \"He\", \"t\": 111.38}, {\"w\": \"thinks\", \"t\": 111.52}, {\"w\": \"he\", \"t\": 111.68}, {\"w\": \"can't\", \"t\": 111.88}, {\"w\": \"use\", \"t